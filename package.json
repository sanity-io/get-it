{
  "name": "get-it",
  "version": "8.7.0",
  "description": "Generic HTTP request library for node, browsers and workers",
  "keywords": [
    "request",
    "http",
    "fetch"
  ],
  "homepage": "https://github.com/sanity-io/get-it#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/get-it/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/get-it.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/_exports/index.ts",
      "react-server": {
        "source": "./src/_exports/index.ts",
        "import": "./dist/index.js"
      },
      "node": {
        "source": "./src/_exports/index.node.ts",
        "import": "./dist/index.node.js"
      },
      "bun": {
        "source": "./src/_exports/index.node.ts",
        "import": "./dist/index.node.js"
      },
      "deno": {
        "source": "./src/_exports/index.node.ts",
        "import": "./dist/index.node.js"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "source": "./src/_exports/middleware.ts",
      "import": "./dist/middleware.js",
      "default": "./dist/middleware.js"
    },
    "./node": {
      "source": "./src/_exports/node.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pkg build --strict --check --clean",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .cjs,.js,.ts --report-unused-disable-directives",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:browser": "pnpm test -- --config ./vitest.browser.config.ts --dom",
    "test:edge-runtime": "pnpm test -- --config ./vitest.edge.config.ts",
    "test:react-server": "pnpm test -- --config ./vitest.react-server.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.check-node.json"
  },
  "browserslist": [
    "node >= 20.19",
    "> 0.2%",
    "not dead",
    "not op_mini all"
  ],
  "prettier": "@sanity/prettier-config",
  "dependencies": {
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@sanity/pkg-utils": "^10.4.7",
    "@sanity/prettier-config": "^2.0.3",
    "@sanity/semantic-release-preset": "^5.0.0",
    "@sanity/tsconfig": "^2.1.0",
    "@types/bun": "^1.2.17",
    "@types/debug": "^4.1.12",
    "@types/node": "^20.8.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "happy-dom": "^18.0.1",
    "knip": "^5.85.0",
    "ls-engines": "^0.9.3",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.6",
    "typescript": "5.9.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
