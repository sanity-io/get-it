{
  "name": "get-it",
  "version": "9.0.0-alpha.10",
  "description": "Generic HTTP request library for node, browsers and workers",
  "keywords": [
    "request",
    "http",
    "fetch"
  ],
  "homepage": "https://github.com/sanity-io/get-it#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/get-it/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-io/get-it.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/_exports/index.ts",
      "react-server": {
        "source": "./src/_exports/index.ts",
        "import": "./dist/index.js"
      },
      "node": {
        "source": "./src/_exports/index.node.ts",
        "import": "./dist/index.node.js"
      },
      "bun": {
        "source": "./src/_exports/index.node.ts",
        "import": "./dist/index.node.js"
      },
      "deno": {
        "source": "./src/_exports/index.node.ts",
        "import": "./dist/index.node.js"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "source": "./src/_exports/middleware.ts",
      "import": "./dist/middleware.js",
      "default": "./dist/middleware.js"
    },
    "./node": {
      "source": "./src/_exports/node.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./mock": {
      "source": "./src/_exports/mock.ts",
      "import": "./dist/mock.js",
      "default": "./dist/mock.js"
    },
    "./vitest": {
      "source": "./src/_exports/vitest.ts",
      "import": "./dist/vitest.js",
      "default": "./dist/vitest.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/*.min.*",
    "src"
  ],
  "scripts": {
    "build": "pkg build --strict --check --clean",
    "check": "pnpm run format && pnpm run lint:fix && pnpm run knip && pnpm run typecheck",
    "coverage": "vitest run --coverage",
    "format": "prettier --ignore-path .gitignore --cache --write .",
    "knip": "knip",
    "lint": "eslint --report-unused-disable-directives",
    "lint:fix": "eslint --report-unused-disable-directives --fix",
    "prepublishOnly": "pnpm run build",
    "report-size": "scripts/report-size.sh",
    "test": "vitest run",
    "test:all": "pnpm run test && pnpm run test:happy-dom && pnpm run test:bun && pnpm run test:edge-runtime && pnpm run test:react-server",
    "test:browser": "pnpm test --config ./vitest.browser.config.ts",
    "test:bun": "bun run vitest run",
    "test:edge-runtime": "pnpm test --config ./vitest.edge.config.ts",
    "test:happy-dom": "pnpm test --config ./vitest.happy-dom.config.ts --dom",
    "test:react-server": "pnpm test --config ./vitest.react-server.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.check-node.json"
  },
  "browserslist": [
    "node >= 22",
    "> 0.27%",
    "not dead",
    "not op_mini all"
  ],
  "prettier": "@sanity/prettier-config",
  "dependencies": {
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@sanity/pkg-utils": "^10.4.18",
    "@sanity/prettier-config": "^3.0.0",
    "@sanity/semantic-release-preset": "^6.0.0",
    "@sanity/tsconfig": "^2.1.0",
    "@types/node": "^22.0.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.14.1",
    "ls-engines": "^0.10.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "semantic-release": "^25.0.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "packageManager": "pnpm@11.2.1",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "react-server": {
          "import": "./dist/index.js"
        },
        "node": {
          "import": "./dist/index.node.js"
        },
        "bun": {
          "import": "./dist/index.node.js"
        },
        "deno": {
          "import": "./dist/index.node.js"
        },
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./middleware": {
        "import": "./dist/middleware.js",
        "default": "./dist/middleware.js"
      },
      "./node": {
        "import": "./dist/node.js",
        "default": "./dist/node.js"
      },
      "./mock": {
        "import": "./dist/mock.js",
        "default": "./dist/mock.js"
      },
      "./vitest": {
        "import": "./dist/vitest.js",
        "default": "./dist/vitest.js"
      },
      "./package.json": "./package.json"
    }
  }
}
