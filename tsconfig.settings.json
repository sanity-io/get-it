{
  "extends": "@sanity/tsconfig/strictest",
  "compilerOptions": {
    // Only ES — no DOM, no node. Each check config adds its own
    // platform types (DOM or @types/node) so we can verify the
    // library compiles cleanly in both environments.
    "lib": ["ES2022"],

    "outDir": "./dist",
    "rootDir": ".",

    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,

    "paths": {
      "get-it": ["./src/_exports/index.ts"],
      "get-it/middleware": ["./src/_exports/middleware.ts"],
      "get-it/node": ["./src/_exports/node.ts"]
    }
  }
}
