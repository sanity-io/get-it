{
  "extends": "@sanity/tsconfig/strictest",
  "compilerOptions": {
    "paths": {
      "get-it": ["./src"],
      "get-it/middleware": ["./src/middleware"],
      "get-it/node": ["./src/node"]
    },

    "outDir": "./dist",
    "rootDir": ".",

    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false
  }
}
